extends ../../layouts/_layout-bg.pug

block vars
  - var title = 'ZT Code Craft | PartDepot'
  - var assetPath = '../../'
  - var altLangUrl = '/en/portfolio/partdepot.html'

block extraStyles
  link(rel='stylesheet' media='screen' href='../../assets/vendor/aos/dist/aos.css')
  link(rel='stylesheet' media='screen' href='../../assets/vendor/swiper/swiper-bundle.min.css')

block content
  //- Hero
  section.position-relative.mb-5
    .bg-secondary.position-absolute.top-0.end-0.w-50.h-100.d-none.d-lg-block
    .bg-secondary.position-absolute.top-0.end-0.w-100.h-100.d-lg-none
    .container.position-relative.zindex-2.py-5.pb-lg-0
      nav(aria-label='breadcrumb')
        ol.pt-lg-2.pb-1.breadcrumb
          li.breadcrumb-item: a(href='/bg/index.html') Начало
          li.breadcrumb-item: a(href='/bg/portfolio.html') Проекти
          li.breadcrumb-item.active(aria-current='page') PArtDepot
      .d-lg-flex.align-items-center.pt-3.pb-xxl-5
        img.d-block.order-lg-2.me-auto.me-lg-0.ms-auto(src='../../assets/img/portfolio/partdepot/part-transp.png' width='480' alt='Image')
        .order-lg-1.text-center.text-lg-start.pe-lg-4.py-4.py-md-5
          h1.display-2.text-uppercase.pb-3.pb-lg-4 Създаване на дигитално платно
          p.fs-lg.mx-auto.mx-lg-0.mb-0(style='max-width: 530px;') Подпомагаме бизнеса на PartDepot: от интегриране на персонализиран дизайн до динамично управление на съдържанието с Contentful платформата.
      ul.nav.justify-content-center.justify-content-lg-start.mx-n2.pt-lg-5.mb-0
        li.nav-item.me-3: a.nav-link.p-2(href='https://www.instagram.com/p_artdepot/' target='_blank') Instagram
        li.nav-item.me-3: a.nav-link.p-2(href='https://www.facebook.com/profile.php?id=100092269797665' target='_blank') Facebook

  //- Content
  section.container.overflow-hidden.pt-lg-2.pt-xl-4.pt-xxl-5
    .row.py-sm-3.py-md-4.py-lg-5
      //- Sticky sidebar
      .col-md-3.col-lg-2
        .d-flex.d-md-block.flex-wrap.position-sticky.top-0
          .pb-3.mb-2.mb-lg-4.me-5.me-md-0
            h2.fs-base.fw-normal.text-muted.mb-2 Компания
            ul.list-unstyled.fs-lg.fw-semibold.text-dark.mb-0
              li.d-block.py-1 PArtDepot
              li.d-block.py-1 5-10 служители
              li.d-block.py-1 Бургас, България
              li.d-block.py-1: a.text-dark(href='https://ztcodecraft.github.io/PArtDepot/' target='_blank') Посетете уебсайта
          .pb-3.mb-2.mb-lg-4.me-5.me-md-0
            h2.fs-base.fw-normal.text-muted.mb-2 Сфера
            ul.list-unstyled.fs-lg.fw-semibold.text-dark.mb-0
              li.d-block.py-1 Изкуство и Забавления
          .pb-3.mb-2.mb-lg-4.me-5.me-md-0
            h2.fs-base.fw-normal.text-muted.mb-2 Services
            ul.list-unstyled.fs-lg.fw-semibold.text-dark.mb-0
              li.d-block.py-1 Web Development
              li.d-block.py-1 Dynamic Custom Content
          .pb-3.mb-2.mb-lg-4
            h2.fs-base.fw-normal.text-muted.mb-2 Времетраене на проекта
            ul.list-unstyled.fs-lg.fw-semibold.text-dark.mb-0
              li.d-block.py-1 2023, 1-2 месеца

      //- Description
      .col-md-9.offset-lg-1
        .ps-md-4.ps-lg-0
          .border-bottom.pb-3.pb-sm-4.pb-lg-5.mb-4
            p.text-dark.lead.mb-md-2.mb-lg-3.mb-xl-4 Открийте как обновихме онлайн присъствието на PartDepot, безпроблемно интегрирайки тяхния уникален бранд с динамични актуализации на графика им чрез Contentful. Прочетете подробности за нашето творческо сътрудничество.
          h2.h1.pt-2.pt-sm-3.pt-md-4.pt-lg-5.pb-2 За клиента
          p.fs-lg PartDepot е <b>арт студио и културен център</b>, посветен на отключването на потенциала на хората чрез изкуство и физически дейности. С разнообразни дейности, включващи йога, арт терапия и кардио тренировки, PartDepot създава изключителни условия за личностно израстване. Студиото се отдава и под наем на различни арт организации, допринасящи за културни и образователни начинания. Хармонията и балансът на духа и тялото са в основата на философията на PartDepot, ръководейки техния подход към физическото и емоционалното развитие.
          h2.h1.pt-3.pt-sm-4.pt-xl-5.pb-2 Предизвикателството
          p.fs-lg PartDepot, арт студио с жизнена визия, се изправи пред предизвикателството да преведе своята енергична идентичност на марката в ангажиращо онлайн присъствие. С предварително подбрани цветове за брандинг и уникални персонализирани шрифтове, придържането към тези елементи във функционален и визуално привлекателен уебсайт беше ключово предизвикателство. Освен това необходимостта от динамична функция - позволяваща безпроблемни актуализации на графика за тяхната разнообразна програма от дейности – изисква персонализирано решение, което да позволи на PartDepot лесно управление на съдържанието.
          h2.h1.pt-3.pt-sm-4.pt-xl-5.pb-2 Решението
          p.fs-lg.mb-0 Създадохме уебсайт, който улавя същността на тяхния енергичен бранд. Използвайки техните съществуващи цветове на и предпочитани шрифтове, ние осигурихме консистентен и визуално стимулиращ дизайн. Персонализираните илюстрации бяха безпроблемно интегрирани, за да подобрят допълнително уникалността на уебсайта. За да осигурим необходимостта от динамично управление на съдържанието, внедрихме решение с помощта на платформата Contentful. Сега PartDepot има пълен контрол върху техния график на класове, като им дава възможност лесно да правят актуализации в реално време. Резултатът е динамичен, удобен за потребителя уебсайт, който не само отразява артистичния дух на PartDepot, но също така предоставя практически инструменти за ефективна онлайн ангажираност.

    //- Images
    .position-relative.w-100.mx-auto.pb-4.pb-sm-3.pb-md-4(style='max-width: 1043px;')
      img.d-block.position-relative.zindex-5(src='../../assets/img/portfolio/partdepot/2.png' alt='Image' data-aos='fade-down-right' data-aos-duration='1500' data-aos-offset='250')
      img.d-block.position-absolute.top-0.start-0(src='../../assets/img/portfolio/partdepot/3.png' alt='Image' data-aos='zoom-in' data-aos-duration='1200' data-aos-offset='250')
      img.d-block.position-absolute.top-0.start-0.zindex-1(src='../../assets/img/portfolio/partdepot/4.png' alt='Image' data-aos='fade-down' data-aos-duration='800' data-aos-offset='250')
      img.d-block.d-dark-mode-none.position-absolute.top-0.start-0.zindex-2(src='../../assets/img/portfolio/partdepot/5.png' alt='Image' data-aos='fade-left' data-aos-duration='1200' data-aos-offset='250')
      img.d-none.d-dark-mode-block(src='' width='')

    //- Results
    .row.pt-1.pt-sm-3.pt-md-4.pb-5.mb-md-2.mb-lg-3.mb-xl-4.mb-xxl-5
      .col-md-11.col-lg-9.col-xl-8.pb-1.pb-sm-3.pb-md-4
        h2.h1.pb-sm-2.pb-lg-3 Резултати
        p.fs-lg.mb-0 Проектът доведе до <b>модерен и удобен за потребителя уебсайт</b>, който отразява артистичния дух на PartDepot. Вече оборудвани с безпроблемно <b>управление на графика</b>, те могат ефективно да се ангажират с общността си чрез ясни и динамични актуализации.

  //- Parallax background image
  section.jarallax(data-jarallax data-speed='0.6')
    .ratio.ratio-16x9
    .jarallax-img(style='background-image: url(../../assets/img/portfolio/partdepot/mockups.png);')

  //- Testimonials
  section.container.position-relative.zindex-2.py-5.mt-n1.mt-sm-0.mb-1.my-md-3.my-lg-3.my-xl-4.my-xxl-5
    .row.py-md-4.py-lg-5
      .col-md-9.col-lg-7.order-md-2
        .swiper(data-swiper-options='{"spaceBetween":40,"loop":true,"bindedContent":true,"autoHeight":true,"pagination":{"el":".testimonials-count","type":"fraction"},"navigation":{"prevEl":"#prev-testimonial","nextEl":"#next-testimonial"}}')
          div
            div
              .d-flex.d-md-none.pt-3.mb-3
                i.ai-quotes.d-md-none.text-primary.display-3.mt-n2
                .ps-3
                  h3.h5.mb-0 Памела Трифонова
                  p.text-muted.mb-0 Собственик на Part Depot
              h2.mb-lg-4 Чудесна работа и отношение!
              p.lead.mb-0 Работа по сайта беше изцяло съобразена с времето с което разполагах, дистанционните онлайн срещи бяха ключови за оформяне на визията и концепцията. Процеса беше изключително лек и приятен, имайки впредвид информационната ми неграмотност на моменти, екипът беше изключително търпелив и подробно ме водеха през отделните етапи във оформянето и развитието на сайта. Съдействаха ми както във визуалните елементи и дизайна, така и в избора на подходящ домейн. Определено бих ги препоръчала на свои познати стартиращи своите бизнеси.
      .col-md-3.offset-lg-1.order-md-1.mt-n3
        i.ai-quotes.d-none.d-md-block.text-primary.ms-n2.mb-1(style='font-size: 150px;')
        .binded-content.h-auto.d-none.d-md-block
          .binded-item.h-auto.active#testimonial-1
            h3.h5.mb-1 Памела Трифонова
            p.text-muted.mb-0 Собственик на Part Depot

  //- Next projects
  section.container.pb-5.mb-2.mb-lg-3.mb-xl-4.mb-xxl-5
    h2.h1.pb-3.pb-lg-4 Следващ проект
    .row.row-cols-1.row-cols-sm-2.align-items-end.mb-2.pb-md-4
      .col
        .zoom-effect.position-relative.border-bottom.pb-3(style='max-width: 550px;')
          .zoom-effect-wrapper
            .zoom-effect-img: img(src='../../assets/img/portfolio/magenta/grid.png' alt='Image')
          .pt-4.mt-lg-2
            h2.h4.mb-2: a.stretched-link(href='magenta-zine.html') Magenta Zine
            .d-flex.justify-content-between.fs-lg.text-muted
              span Уебсайт, Блог, Брандинг
              span 2023

block extraScripts
  script(src='../../assets/vendor/aos/dist/aos.js')
  script(src='../../assets/vendor/jarallax/dist/jarallax.min.js')
  script(src='../../assets/vendor/swiper/swiper-bundle.min.js')
